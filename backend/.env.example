# Database connection
# For development (SQLite): file:./prisma/dev.db
# For production (PostgreSQL): postgresql://user:password@localhost:5432/dbname
DATABASE_URL="file:./prisma/dev.db"

# JWT secret - REQUIRED! Generate with: openssl rand -base64 64
# NEVER use the default value in production!
JWT_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-64"

# CORS origin (frontend URL)
CORS_ORIGIN="http://localhost:4200"